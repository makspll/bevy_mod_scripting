    set: func(self: bvec3-a, index: u64, value: bool);
}

/// Methods for BVec4
interface bvec4 {
    use types.{reflect-reference};

    ///  Creates a new vector mask from a bool array.
    from-array: func(a: list<bool>) -> bvec4;
    ///  Tests the value at `index`.
    ///  Panics if `index` is greater than 3.
    test: func(self: bvec4, index: u64) -> bool;
    ///  Returns true if any of the elements are true, false otherwise.
