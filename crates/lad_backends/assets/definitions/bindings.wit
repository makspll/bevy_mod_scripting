    div: func(self: xyza, rhs: f32) -> xyza;
    neg: func(self: xyza) -> xyza;
    ///  Return a copy of this color with the 'z' channel set to the given value.
    with-z: func(self: xyza, z: f32) -> xyza;
    ///  Construct a new [`Xyza`] color from (x, y, z) components, with the default alpha (1.0).
    xyz: func(x: f32, y: f32, z: f32) -> xyza;
    mul: func(self: xyza, rhs: f32) -> xyza;
    add: func(self: xyza, rhs: xyza) -> xyza;
