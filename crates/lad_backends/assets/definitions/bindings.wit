    assert-receiver-is-total-eq: func(self: bvec4);
    eq: func(self: bvec4, other: bvec4) -> bool;
    ///  Returns a bitmask with the lowest 4 bits set from the elements of `self`.
    ///  A true element results in a `1` bit and a false element in a `0` bit.  Element `x` goes
    ///  into the first lowest bit, element `y` into the second, etc.
    bitmask: func(self: bvec4) -> u32;
    ///  Creates a vector mask with all elements set to `v`.
    splat: func(v: bool) -> bvec4;
    ///  Returns true if all the elements are true, false otherwise.
    all: func(self: bvec4) -> bool;
    clone: func(self: bvec4) -> bvec4;
}

/// Methods for BVec4A
